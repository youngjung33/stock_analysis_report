generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(uuid())
  username         String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  refreshTokens    RefreshToken[]
  transactions     Transaction[]
  corporateActions CorporateAction[]
  watchlistItems   WatchlistItem[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Stock {
  id               String            @id @default(uuid())
  symbol           String
  name             String
  market           String
  currency         String
  yahooSymbol      String?
  createdAt        DateTime          @default(now())
  transactions     Transaction[]
  quote            StockQuote?
  corporateActions CorporateAction[] @relation("ActionStock")
  mergerTargets    CorporateAction[] @relation("MergerTarget")

  @@unique([symbol, market])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  stockId   String
  type      String
  quantity  Float
  price     Float
  tradedAt  DateTime
  memo      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stockId])
}

model StockQuote {
  stockId       String   @id
  currentPrice  Float
  changePercent Float?
  fetchedAt     DateTime
  stock         Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
}

/// 종목 검색용 마스터 (fetch:stocks → JSON → Supabase 임포트)
model StockCatalog {
  id          String   @id @default(uuid())
  symbol      String
  name        String
  market      String
  board       String
  yahooSymbol String
  isActive    Boolean  @default(true)
  syncedAt    DateTime @default(now())

  @@unique([symbol, market])
  @@index([market, isActive])
}

model CorporateAction {
  id             String   @id @default(uuid())
  userId         String
  stockId        String
  type           String
  effectiveAt    DateTime
  cashAmount     Float?
  splitRatio     Float?
  targetStockId  String?
  targetQuantity Float?
  targetPrice    Float?
  memo           String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock          Stock    @relation("ActionStock", fields: [stockId], references: [id], onDelete: Cascade)
  targetStock    Stock?   @relation("MergerTarget", fields: [targetStockId], references: [id])

  @@index([userId])
  @@index([stockId])
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  name      String
  market    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, market])
}
